{
  "name": "hfac-market-making",
  "version": "1.0.0",
  "description": "HFAC Market Making Trading Game",
  "private": true,
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npx vite --host",
    "build:client": "cd client && npx vite build",
    "start": "node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
